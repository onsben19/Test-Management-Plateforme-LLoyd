@startuml
' --- Configuration Globale ---
skinparam classAttributeIconSize 0
skinparam style strictuml
skinparam linetype ortho
hide empty members

skinparam class {
  BackgroundColor #FBFBFF
  BorderColor #2F2F4F
  HeaderBackgroundColor #E2E1F5
  FontSize 12
  AttributeFontSize 11
}

title Diagramme de Classes Complet — Plateforme InsureTM (Standard PFE)

' --- Configuration Layout ---
skinparam nodesep 80
skinparam ranksep 80

' --- Analytics AI Agent ---
class AIConversation {
    - id : UUID
    - title : String
    - created_at : DateTime
}

class AIMessage {
    - id : Integer
    - sender : Choice {USER, AGENT}
    - text : Text
    - type : String
    - sql : Text
    - data : JSON
    - image : File
}

' --- Énumérations (Types) ---

enum RoleType <<enumeration>> {
    ADMINISTRATEUR
    MANAGER
    TESTEUR
}

enum StatutRelease <<enumeration>> {
    EN_PLANIFICATION
    ACTIF
    TERMINE
}

enum TypeRelease <<enumeration>> {
    PREPROD
    RECETTE
}

enum StatutTest <<enumeration>> {
    EN_ATTENTE
    SUCCES
    ECHEC
    BLOQUE
}

enum ImpactAnomalie <<enumeration>> {
    FONCTIONNALITE
    SIMPLE
    TEXTE
    COSMETIQUE
    MINEUR
    MAJEUR
    CRITIQUE
    BLOQUANTE
}

enum PrioriteAnomalie <<enumeration>> {
    BASSE
    NORMALE
    ELEVEE
    URGENTE
    IMMEDIATE
}

enum StatutAnomalie <<enumeration>> {
    OUVERTE
    EN_INVESTIGATION
    RESOLUE
    FERMEE
}

enum TypeConversation <<enumeration>> {
    DIRECTE
    GROUPE
}

' --- Classes Identity & Access ---

class User {
    - id : Integer
    - username : String
    - email : String
    - password : String
    - role : RoleType
    - is_active : Boolean
    - date_joined : DateTime
    + save()
    + generate_random_password()
}

' --- Héritage des Rôles ---
User <|-- Administrateur
User <|-- ManagerQA
User <|-- Testeur

' --- Core Business ---

class Projets {
    - id : Integer
    - name : String
    - description : Text
    - created_at : DateTime
    - created_by : User
}

class Release {
    - id : Integer
    - name : String
    - description : Text
    - status : StatutRelease
    - release_type : TypeRelease
    - created_at : DateTime
    - business_project : Projets
    - created_by : User
    + campaign_count : Integer
}

' --- Exécution & Campagnes ---

class Campaign {
    - id : Integer
    - title : String
    - description : Text
    - start_date : Date
    - estimated_end_date : Date
    - nb_test_cases : Integer
    - excel_file : File
    - created_at : DateTime
    - scheduled_at : DateTime
}

class CasDeTest {
    - id : Integer
    - reference_tc : String
    - donnees_json : JSON
    - statut : StatutTest
    - date_execution : DateTime
    - fichier_preuve : File
}

' --- Qualité & Anomalies ---

class Anomalie {
    - id : Integer
    - titre : String
    - description : Text
    - impact : ImpactAnomalie
    - priorite : PrioriteAnomalie
    - visibilite : Choice {PUBLIQUE, PRIVEE}
    - statut : StatutAnomalie
    - preuve_image : File
    - date_creation : DateTime
    - auteur : User
    - assigne_a : User
    - cas_de_test : CasDeTest
}

' --- Analytics ---

class RapportReadiness {
    - id : Integer
    - score_total : Float
    - score_tests : Float
    - score_anomalies : Float
    - score_stabilite : Float
    - score_securite : Float
    - recommandations : List<String>
    - date_generation : DateTime
    - niveau_risque : String
    + genererPDF() : File
}

' --- Communication ---

class Conversation {
    - id : Integer
    - titre : String
    - type : TypeConversation
    - date_creation : DateTime
}

class Message {
    - id : Integer
    - contenu : Text
    - piece_jointe : File
    - est_modifie : Boolean
    - date_envoi : DateTime
}

class Mail {
    - id : Integer
    - texte : Text
    - piece_jointe : File
    - date_creation : DateTime
    - date_modification : DateTime
    - auteur : User
    - destinataire : User
}

' --- Relations Structurelles ---

Projets "1" *-- "0..*" Release : contenir >
Release "1" *-- "0..*" Campaign : planifier >
Campaign "1" *-- "0..*" CasDeTest : composer >
CasDeTest "1" *-- "0..*" Anomalie : générer >

Release "1" -- "0..1" RapportReadiness : évaluer >

' --- Relations User ---

' --- Relations User ---

User "1" -right- "0..*" Projets : être propriétaire de >
ManagerQA "1" -right- "0..*" Release : gérer >
Testeur "0..*" -down-> "0..*" Campaign : être assigné à >
Testeur "1" -down-> "0..*" CasDeTest : exécuter >
User "1" -right-> "0..*" Anomalie : signaler >

' --- Communication Relations ---

User "1" -left-> "0..*" Message : créer >
User "1" -up-> "0..*" Mail : envoyer / recevoir >
User "2..*" -left-> "0..*" Conversation : participer à >
Conversation "1" *-- "0..*" Message : contenir >

User "1" -right-> "0..*" AIConversation : consulter >
AIConversation "1" *-- "0..*" AIMessage : contenir >

' --- Liens Énumérations ---
Release ..> StatutRelease : uses
Release ..> TypeRelease : uses
CasDeTest ..> StatutTest : uses
Anomalie ..> ImpactAnomalie : uses
Anomalie ..> PrioriteAnomalie : uses
Anomalie ..> StatutAnomalie : uses
Conversation ..> TypeConversation : uses
User ..> RoleType : uses

@enduml



