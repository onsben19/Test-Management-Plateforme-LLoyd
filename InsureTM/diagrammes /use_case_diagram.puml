@startuml
skinparam actorStyle awesome
left to right direction

title Diagramme de cas d'utilisation - Plateforme InsureTM

actor "Testeur" as T
actor "Manager" as M
actor "Admin" as A

package "Plateforme InsureTM" {
    
    usecase "S'authentifier" as Auth
    
    ' Cas pour le Testeur
    usecase "Valider cas de test" as UC1
    usecase "Signaler Anomalie" as UC2
    usecase "Exporter files PDF/CSV" as UC_Export
    usecase "Gérer tickets (Mailing)" as UC3
    usecase "Communiquer via Chat" as UC4
    usecase "Utiliser Assistant IA Personnalisé" as UC5
    usecase "Visualiser Dashboard Score IA" as UC6
    usecase "Explication détaillée IA" as UC_Expl
    
    ' Cas pour le Manager
    usecase "Publier Projets" as UC7
    usecase "Gérer Releases" as UC8
    usecase "Gérer les cahiers de charge" as UC9
    usecase "Assigner des Testeurs" as UC10
    
    ' Cas pour l'Admin
    usecase "Gérer les utilisateurs et comptes" as UC11
    
    ' Relations d'extension (Pointillés vers le cas de base)
    UC_Export .up.> UC2 : <<extend>>
    UC_Expl .up.> UC6 : <<extend>>
    
    ' Relations d'inclusion (Vers S'authentifier)
    UC3 ..> Auth : <<include>>
    UC4 ..> Auth : <<include>>
    UC5 ..> Auth : <<include>>
    UC6 ..> Auth : <<include>>
    UC7 ..> Auth : <<include>>
    UC8 ..> Auth : <<include>>
    UC9 ..> Auth : <<include>>
    UC10 ..> Auth : <<include>>
    UC11 ..> Auth : <<include>>
}

' Systèmes Externes
entity "<<system>>\nModèle IA Groq" as Groq
entity "<<system>>\nServeur SMTP" as SMTP

' Associations Acteurs -> Cas
T -- UC1
T -- UC2
T -- UC3
T -- UC4
T -- UC5
T -- UC6

M -- UC7
M -- UC8
M -- UC9
M -- UC10
M -- UC4
M -- UC6

A -- UC11

' Liaisons Systèmes secondaires
UC3 -- SMTP
UC5 -- Groq
UC6 -- Groq

@enduml
