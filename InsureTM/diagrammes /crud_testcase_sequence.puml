@startuml
autonumber
skinparam style strictuml
skinparam sequenceMessageAlign center

actor "Testeur" as T
participant "Interface (React)" as F
participant "API (Django)" as B
database "Base de Données" as DB

title CRUD : Exécution d'un Cas de Test

T -> F : Sélectionner un Cas de Test dans la liste
F -> B : GET /api/testcases/{id}/
B --> F : Détails JSON (Étapes, Résultats attendus)
T -> F : Sélectionner Statut (SUCCES/ECHEC)
T -> F : Joindre Capture d'Écran (Preuve)
F -> B : PATCH /api/testcases/{id}/ (Multipart)
B -> B : Stockage du fichier & Horodatage
B -> DB : Mise à jour de l'enregistrement TestCase
B -> B : Broadcast Temps Réel (WebSocket)
B --> F : 200 OK
F --> T : Mise à jour visuelle (Badge Statut)
@enduml
