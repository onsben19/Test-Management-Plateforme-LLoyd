@startuml
autonumber
skinparam style strictuml
skinparam sequenceMessageAlign center

participant "Logique Métier" as BE
participant "Service Email" as ES
participant "Django Core Mail" as DCM
participant "Serveur SMTP" as SMTP

title Flux : Envoi de Notifications par Email

BE -> ES : call envoyer_email_notification(utilisateur, objet)
ES -> ES : Vérifier le flag EMAILS_ENABLED
alt EMAILS_ENABLED == False (Bloqué)
    ES -> ES : Journaliser "[EMAILS BLOCKED] ..."
    ES --> BE : Retour (Aucune action)
else EMAILS_ENABLED == True (Actif)
    ES -> DCM : send_mail(sujet, corps, destinataires)
    DCM -> SMTP : Protocole SMTP (TLS/SSL)
    SMTP --> DCM : 250 OK (Accepté)
    ES --> BE : Succès de l'envoi
end
@enduml
