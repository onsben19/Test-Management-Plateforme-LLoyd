@startuml
autonumber
skinparam style strictuml
skinparam sequenceMessageAlign center

actor "Manager QA" as M
participant "Interface (React)" as F
participant "API (Django)" as B
participant "Worker (Celery)" as C
database "Base de Données" as DB

title CRUD : Création & Importation de Campagne

M -> F : Sélectionner une Release (Projet)
F -> B : GET /api/projects/{id}/
B --> F : Détails de la Release
M -> F : Charger Référentiel Excel & Titre
F -> B : POST /api/campaigns/ (Multipart)
B -> DB : Créer l'enregistrement Campagne (Statut=EN_COURS)
B -> C : Déclencher tâche 'process_campaign_excel'
C -> C : Parser l'Excel & Mapper les colonnes
C -> DB : Création en masse des Cas de Test
C -> C : Recalculer les statistiques de couverture
C -> DB : Mettre à jour Campagne (est_traite=True)
B --> F : 202 Accepté
F --> M : Toast "Traitement du référentiel en cours..."
@enduml
