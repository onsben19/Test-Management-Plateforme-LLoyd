@startuml

title Diagramme de Séquence : Réinitialisation de Mot de Passe\nInsureTM - Plateforme de Gestion de Campagnes de Test Lloyd

skinparam Shadowing false
hide footbox
skinparam ParticipantPadding 15

skinparam sequence {
    ArrowColor #000000
    ActorBorderColor #000000
    LifeLineBorderColor #000000
    LifeLineBackgroundColor #FFFFFF
    ParticipantBorderColor #000000
    ParticipantBackgroundColor #FFFFFF
    ParticipantFontName Helvetica
    ParticipantFontSize 12
    ParticipantFontColor #000000
    ActorBackgroundColor #FFFFFF
    ActorFontName Helvetica
    ActorFontSize 12
    ActorFontColor #000000
}

actor ":Utilisateur" as User
participant "«IHM»\nInterface React" as Frontend
participant "«Contrôleur»\nBackend Django" as Backend
participant "«Service»\nService Email" as Email
database "«Entité»\nBase de Données" as DB

group Demande de réinitialisation

    User -> Frontend: accederPageMotDePasseOublie()
    User -> Frontend: saisirIdentifiant(email ou username)
    User -> Frontend: clicReinitialiser()
    Frontend -> Backend: demanderReinitialisation(identifier)
    activate Backend

    alt Identifiant non fourni
        Backend --> Frontend: retours erreur(HTTP 400,\n"Identifiant requis")
        Frontend --> User: afficherErreur("Veuillez saisir votre identifiant")
    else Identifiant fourni

        Backend -> DB: rechercherUtilisateur(\nemail == identifier OU username == identifier)
        activate DB
        DB --> Backend: retours resultatRecherche()
        deactivate DB

        alt Compte introuvable
            note right of Backend
                Mesure de sécurité :
                le système ne révèle pas
                si le compte existe ou non
            end note
            Backend --> Frontend: retours messageGenerique(HTTP 200)
        else Compte trouvé

            Backend -> Backend: genererNouveauMotDePasse(length=12)
            Backend -> DB: mettreAJourMotDePasse(passwordHash)
            activate DB
            DB --> Backend: retours confirmation()
            deactivate DB

            Backend -> Email: envoyerEmailReinitialisation(\nutilisateur, nouveauMotDePasse)
            activate Email
            Email --> Backend: retours emailEnvoye()
            deactivate Email

            Backend --> Frontend: retours messageGenerique(HTTP 200)
            deactivate Backend

        end

        Frontend --> User: afficherMessage(\n"Si votre compte existe,\nun nouveau mot de passe\nvous a été envoyé.")

    end

end

@enduml
