@startuml
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 80

title Diagramme de Classes Complet — Plateforme InsureTM

' --- ENUMS ---
enum RoleType <<enumeration>> {
  ADMINISTRATEUR
  MANAGER
  TESTEUR
}

enum StatutRelease <<enumeration>> {
  EN_PLANIFICATION
  ACTIF
  TERMINE
}

enum TypeRelease <<enumeration>> {
  PREPROD
  RECETTE
}

enum StatutTest <<enumeration>> {
  EN_ATTENTE
  SUCCES
  ECHEC
  BLOQUE
}

enum ImpactAnomalie <<enumeration>> {
  FONCTIONNALITE
  SIMPLE
  TEXTE
  COSMETIQUE
  MINEUR
  MAJEUR
  CRITIQUE
  BLOQUANTE
}

enum PrioriteAnomalie <<enumeration>> {
  BASSE
  NORMALE
  ELEVEE
  URGENTE
  IMMEDIATE
}

enum StatutAnomalie <<enumeration>> {
  OUVERTE
  EN_INVESTIGATION
  RESOLUE
  FERMEE
}

enum TypeConversation <<enumeration>> {
  DIRECTE
  GROUPE
}

' --- CLASSES ---
class User {
  - id : Integer
  - username : String
  - email : String
  - password : String
  - role : RoleType
  - is_active : Boolean
  - date_joined : DateTime
  - otp_code : String
  - otp_expiry : DateTime
  - avatar : ImageFile
  + save()
  + generate_random_password()
}

class ManagerQA
class Testeur
class Administrateur

class Projets {
  - id : Integer
  - name : String
  - description : Text
  - created_at : DateTime
  - created_by : User
}

class Release {
  - id : Integer
  - name : String
  - description : Text
  - status : StatutRelease
  - release_type : TypeRelease
  - created_at : DateTime
  - business_project : Projets
  - created_by : User
  + campaign_count : Integer
}

class Campaign {
  - id : Integer
  - title : String
  - description : Text
  - project : Projets
  - start_date : Date
  - estimated_end_date : Date
  - nb_test_cases : Integer
  - excel_file : File
  - created_at : DateTime
  - scheduled_at : DateTime
  - imported_by : User
}

class CampaignAssignment {
  - campaign : Campaign
  - tester : User
  - test_quota : Integer
  - assigned_at : DateTime
}

class TaskAssignment {
  - campaign : Campaign
  - tester : User
  - test_case_ref : String
  - assigned_at : DateTime
  - is_completed : Boolean
}

class CasDeTest {
  - id : Integer
  - reference_tc : String
  - campaign : Campaign
  - donnees_json : JSON
  - statut : StatutTest
  - date_execution : DateTime
  - fichier_preuve : File
  - proof_hash : String
  - proof_video : File
  - automation_code : Text
  - execution_logs : Text
}

class Anomalie {
  - id : Integer
  - titre : String
  - description : Text
  - impact : ImpactAnomalie
  - priorite : PrioriteAnomalie
  - visibilite : Choice {PUBLIQUE, PRIVEE}
  - statut : StatutAnomalie
  - preuve_image : File
  - date_creation : DateTime
  - auteur : User
  - assigne_a : User
  - cas_de_test : CasDeTest
  - is_auto_generated : Boolean
}

class RapportReadiness {
  - id : Integer
  - score_total : Float
  - score_tests : Float
  - score_anomalies : Float
  - score_stabilite : Float
  - score_securite : Float
  - recommandations : List<String>
  - date_generation : DateTime
  - niveau_risque : String
  + genererPDF() : File
}

class AIConversation {
  - id : UUID
  - title : String
  - created_at : DateTime
}

class AIMessage {
  - id : Integer
  - sender : Choice {USER, AGENT}
  - text : Text
  - type : String
  - sql : Text
  - data : JSON
  - image : File
}

class Conversation {
  - id : Integer
  - titre : String
  - type : TypeConversation
  - date_creation : DateTime
}

class Message {
  - id : Integer
  - contenu : Text
  - piece_jointe : File
  - est_modifie : Boolean
  - date_envoi : DateTime
}

class Mail {
  - id : Integer
  - texte : Text
  - piece_jointe : File
  - date_creation : DateTime
  - date_modification : DateTime
  - auteur : User
  - destinataire : User
}

class QANews {
  - id : Integer
  - title : String
  - url : String
  - source : String
  - content_summary : Text
  - ai_tip : Text
  - published_date : DateTime
  - created_at : DateTime
}

' --- RELATIONS ---
User <|-- ManagerQA
User <|-- Testeur
User <|-- Administrateur

User "1" -right-> "0..*" Projets : être propriétaire de >
Projets "1" *-down- "0..*" Release : contenir >
User "1" --> "0..*" Release : planifier >
Release "1" *-down- "0..*" Campaign : composer >
Release "1" -right-> "0..1" RapportReadiness : évaluer >

Campaign "1" *-- "0..*" CasDeTest : composer >
Campaign "1" *-- "0..*" CampaignAssignment : gérer quotas >
Campaign "1" *-- "0..*" TaskAssignment : affecter tâches >
CasDeTest "1" *-- "0..*" Anomalie : générer >

Testeur "0..*" --> "0..*" Campaign : être assigné à >
Testeur "1" --> "0..*" CasDeTest : exécuter >
Testeur "1" --> "0..*" Anomalie : signaler >
CampaignAssignment "0..*" --> "1" Testeur : concerner >
TaskAssignment "0..*" --> "1" Testeur : concerner >

User "1" -left-> "0..*" AIConversation : consulter >
AIConversation "1" *-down- "0..*" AIMessage : contenir >

User "1" -down-> "0..*" Conversation : participer à >
Conversation "1" *-down- "0..*" Message : contenir >
User "1" --> "0..*" Message : créer >

User "1" --> "0..*" Mail : envoyer / recevoir >
User "1" -down-> "0..*" QANews : <<use>> consulter >

User ..> RoleType : uses
Release ..> StatutRelease : uses
Release ..> TypeRelease : uses
CasDeTest ..> StatutTest : uses
Anomalie ..> ImpactAnomalie : uses
Anomalie ..> PrioriteAnomalie : uses
Anomalie ..> StatutAnomalie : uses
Conversation ..> TypeConversation : uses

@enduml
