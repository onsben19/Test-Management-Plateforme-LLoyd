@startuml

title Vue Runtime Détaillée - Messagerie Interne et Chat Collaboratif\nInsureTM - Plateforme de Gestion de Campagnes de Test Lloyd

skinparam Shadowing false
hide footbox
skinparam ParticipantPadding 15

skinparam sequence {
    ArrowColor #000000
    ActorBorderColor #000000
    LifeLineBorderColor #000000
    LifeLineBackgroundColor #FFFFFF
    ParticipantBorderColor #000000
    ParticipantBackgroundColor #FFFFFF
    ParticipantFontName Helvetica
    ParticipantFontSize 12
    ParticipantFontColor #000000
    ActorBackgroundColor #FFFFFF
    ActorFontName Helvetica
    ActorFontSize 12
    ActorFontColor #000000
    NoteBackgroundColor #FFFFCC
    NoteBorderColor #999999
}

actor ":Expéditeur" as Sender

participant "«IHM»\nInterface React" as Frontend
participant "«Contrôleur»\nAPI Django REST" as RestAPI
participant "«WebSocket»\nDjango Channels" as WebSockets
database "«Entité»\nBase de Données" as DB

actor ":Destinataire" as Receiver

alt Messagerie Interne (E-mail in-app)

    group Envoi d'un courriel formel
        Sender -> Frontend: envoyerEmail(sujet, corps, pieceJointe)
        activate Frontend
        Frontend -> RestAPI: POST /api/emails/
        activate RestAPI
        RestAPI -> DB: enregistrerEmail(is_read=False)
        activate DB
        DB --> RestAPI: retours confirmation()
        deactivate DB
        RestAPI --> Frontend: retours http201Created()
        deactivate RestAPI
        Frontend --> Sender: retours afficherSucces()
        deactivate Frontend
    end

    group Consultation de la Boîte de Réception
        Receiver -> Frontend: ouvrirBoiteReception()
        activate Frontend
        Frontend -> RestAPI: GET /api/emails/
        activate RestAPI
        RestAPI --> Frontend: retours listeEmails()
        deactivate RestAPI
        Frontend --> Receiver: retours afficherMessagesNonLus()
        deactivate Frontend
    end

else Chat Temps Réel (Conversation)

    group Connexion WebSocket persistante
        Sender -> Frontend: ouvrirChatCenter()
        Frontend -> WebSockets: connecter(ws/chat/global/?token)
        activate WebSockets
        WebSockets --> Frontend: connexionAcceptee()
        deactivate WebSockets
        Receiver -> Frontend: ouvrirChatCenter()
        Frontend -> WebSockets: connecter(ws/chat/global/?token)
        activate WebSockets
        WebSockets --> Frontend: connexionAcceptee()
        deactivate WebSockets
    end

    group Envoi et réception instantanée d'un message
        Sender -> Frontend: envoyerMessageChat(texte)
        activate Frontend
        Frontend -> RestAPI: POST /api/chat/messages/
        activate RestAPI
        RestAPI -> DB: sauvegarderMessage(conversation, auteur, texte)
        activate DB
        DB --> RestAPI: retours messageCree()
        deactivate DB
        RestAPI -> WebSockets: diffuser(chat_message, payload)
        activate WebSockets
        RestAPI --> Frontend: retours http201Created(message)
        deactivate RestAPI
        WebSockets -> Frontend: chat_message(JSON)
        deactivate WebSockets
        Frontend --> Receiver: afficherMessageSansRefresh()
        Frontend --> Sender: confirmerEnvoi(check)
        deactivate Frontend
    end

    group Indicateur « écrit... »
        Sender -> Frontend: saisirTexte(message)
        activate Frontend
        Frontend -> WebSockets: envoyer(typing, conversation_id, is_typing=true)
        activate WebSockets
        WebSockets -> Frontend: chat_typing(username)
        deactivate WebSockets
        Frontend --> Receiver: afficherEcrit(username)
        deactivate Frontend
    end

    group Accusé de lecture « Vu »
        Receiver -> Frontend: ouvrirConversation()
        activate Frontend
        Frontend -> RestAPI: POST /api/chat/conversations/{id}/mark_read/
        activate RestAPI
        RestAPI -> DB: mettreAJour(ConversationReadCursor)
        activate DB
        DB --> RestAPI: retours curseurLu()
        deactivate DB
        RestAPI -> WebSockets: diffuser(chat_read, last_read_message_id)
        activate WebSockets
        RestAPI --> Frontend: retours http200OK()
        deactivate RestAPI
        WebSockets -> Frontend: chat_read(JSON)
        deactivate WebSockets
        Frontend --> Sender: afficherVu(doubleCheckBleu)
        deactivate Frontend
    end

end

@enduml
