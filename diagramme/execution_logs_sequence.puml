@startuml

title Diagramme de Séquence : Exécution Automatisée Playwright et Suivi des Logs\nInsureTM - Plateforme de Gestion de Campagnes de Test Lloyd

skinparam Shadowing false
hide footbox
skinparam ParticipantPadding 15

skinparam sequence {
    ArrowColor #000000
    ActorBorderColor #000000
    LifeLineBorderColor #000000
    LifeLineBackgroundColor #FFFFFF
    ParticipantBorderColor #000000
    ParticipantBackgroundColor #FFFFFF
    ParticipantFontName Helvetica
    ParticipantFontSize 12
    ParticipantFontColor #000000
    ActorBackgroundColor #FFFFFF
    ActorFontName Helvetica
    ActorFontSize 12
    ActorFontColor #000000
    NoteBackgroundColor #FFFFCC
    NoteBorderColor #999999
}

actor ":Testeur" as Tester
participant "«IHM»\nInterface React" as Front
participant "«Contrôleur»\nBackend Django (API)" as Back
database "«Entité»\nBase PostgreSQL" as DB

group Préparation et génération du script

    Tester -> Front : saisirEtapesTest()
    Tester -> Front : clicGenererScript()
    Front -> Back : genererScriptPlaywright(etapes)
    activate Back
    Back -> Back : genererScriptParIA()
    Back --> Front : retours(scriptGenere)
    deactivate Back

end

group Exécution du test et suivi des logs

    Tester -> Front : choisirMode(headless | headed)
    Tester -> Front : clicExecuterEtEnregistrer()

    Front -> Back : creerCasDeTest(PENDING)
    activate Back
    Back -> DB : enregistrerTestCase()
    DB --> Back : retours(id)
    Back --> Front : retours(id)
    deactivate Back

    Front -> Back : enregistrerScript(code)
    activate Back
    Back --> Front : retours(confirmation)
    deactivate Back

    Front -> Back : lancerExecution(mode)
    activate Back
    Back -> Back : demarrerPlaywright(mode)
    note right of Back
        Thread arrière-plan.
        Headed : navigateur sur Xvfb + noVNC.
    end note
    Back --> Front : retours(RUNNING)
    deactivate Back

    loop Polling HTTP (1,5 s)
        Front -> Back : consulterLogs(id)
        activate Back
        Back --> Front : retours(logs, running)
        deactivate Back
        Front --> Tester : afficherLogs()

        opt Mode Headed
            Front --> Tester : afficherEcranVirtuel(noVNC)
        end
    end

    Back -> Back : finaliserExecution()
    Back -> DB : enregistrerResultat(statut, preuves)
    activate DB
    DB --> Back : retours(confirmation)
    deactivate DB

    Front -> Back : consulterLogs(id)
    activate Back
    Back --> Front : retours(running=false, statut)
    deactivate Back

end

alt statut == FAILED

    Back -> Back : genererAnomalieParIA(logs)
    Back -> DB : creerAnomalie()
    activate DB
    DB --> Back : retours(anomaly_id)
    deactivate DB

    Back --> Front : retours(FAILED, anomaly_id)
    Front --> Tester : afficherEchec()

    opt Voir l'anomalie
        Tester -> Front : clicVoirAnomalie()
        Front --> Tester : ouvrirDetailAnomalie()
    end

else statut == PASSED

    Back --> Front : retours(PASSED)
    Front --> Tester : afficherSucces()

end

@enduml
