DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=backend,insuretb.tech,api.insuretb.tech,n8n.insuretb.tech,*

APP_URL=https://insuretb.tech
FRONTEND_URL=https://insuretb.tech
BACKEND_URL=http://backend:8000
# Internal Docker URL (backend container → n8n container)
N8N_BASE_URL=http://insuretm-n8n:5678
# Shared secret between Django and n8n workflows (openssl rand -hex 32)
N8N_WEBHOOK_TOKEN=insuretm-n8n-secret-2026
DATABASE_URL=postgres://DB_USER:DB_PASSWORD@db:5432/DB_NAME
DB_NAME=insureTM_db
DB_USER=postgres
DB_PASSWORD=your-db-password

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

VANNA_API_KEY=your-vanna-api-key
VANNA_MODEL=your-vanna-model-name
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
